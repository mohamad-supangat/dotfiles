#!/usr/bin/env bash

# Inisialisasi variabel mode fuzzel (default: launcher aplikasi)
FUZZEL_MODE=""
PROMPT_ARG=()
LINES_ARG=()

# Loop untuk membaca semua argumen yang masuk
while [[ $# -gt 0 ]]; do
  case "$1" in
  -dmenu)
    FUZZEL_MODE="-d"
    shift
    ;;
  -show)
    if [[ "$2" == "drun" || "$2" == "run" ]]; then
      FUZZEL_MODE=""
    fi
    shift 2
    ;;
  -p | -prompt)
    PROMPT_ARG=("-p" "$2 > ")
    shift 2
    ;;
  -lines | -l)
    LINES_ARG=("-l" "$2")
    shift 2
    ;;
  *)
    shift
    ;;
  esac
done

# Cek apakah fuzzel tersedia
if command -v fuzzel >/dev/null 2>&1; then
  # Jalankan fuzzel
  if [ "$FUZZEL_MODE" = "-d" ]; then
    exec fuzzel -d "${PROMPT_ARG[@]}" "${LINES_ARG[@]}"
  else
    exec fuzzel "${PROMPT_ARG[@]}" "${LINES_ARG[@]}"
  fi
else
  # Jika fuzzel tidak ada, fallback ke rofi
  if [ "$FUZZEL_MODE" = "-d" ]; then
    exec rofi -dmenu "${PROMPT_ARG[@]}" "${LINES_ARG[@]}"
  else
    exec rofi -show drun "${PROMPT_ARG[@]}" "${LINES_ARG[@]}"
  fi
fi
